# Next Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# nf-id SSO — redirect-token flow
# NF_ID_SECRET must match the NF_ID_SECRET used by the nf-id service
NF_ID_SECRET=replace-with-the-nf-id-shared-secret

# nf-id issuer URL (default: https://id.namfam.co)
AUTH_NFID_ISSUER=https://id.namfam.co

# nf-id client_id registered in nf-id/src/lib/clients.ts (default: partner-portal)
NF_ID_CLIENT_ID=partner-portal

# nf-backstage API base URL
NEXT_PUBLIC_BACKSTAGE_API_URL=https://a.namfam.co
